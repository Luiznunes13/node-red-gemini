#pragma once

// ============================================================
//  CONFIGURAÇÕES DO DEVICE
//  Copie este arquivo para config.h e preencha com seus dados:
//    cp config.h.example config.h
// ============================================================

// ── Identificação ──────────────────────────────────────────
#define DEVICE_ID        "esp8266-01"       // ID único por device
#define FIRMWARE_VERSION "1.0.0"

// ── WiFi ───────────────────────────────────────────────────
#define WIFI_SSID        "SuaRedeWiFi"
#define WIFI_PASSWORD    "SuaSenhaWiFi"

// ── MQTT Broker ────────────────────────────────────────────
#define MQTT_HOST        "192.168.0.X"       // IP do broker (ou URL na nuvem)
#define MQTT_PORT        1883               // 1883 = sem TLS | 8883 = com TLS

// Autenticação MQTT - descomente se o broker exigir
// #define MQTT_USER     "mqttuser"
// #define MQTT_PASSWORD "mqttpassword"

// ── Hardware ───────────────────────────────────────────────
#define LED_PIN          14                 // D5 = GPIO14 (LED conectado)
#define GPIO_ACTIVE_LOW  true               // true = lógica invertida (LOW acende, HIGH apaga)

// ── OTA ────────────────────────────────────────────────────
// Senha para atualização OTA via Arduino IDE
// #define OTA_PASSWORD  "ota_senha"        // descomente para habilitar

// ============================================================
//  EXEMPLOS DE CONFIGURAÇÃO POR AMBIENTE
//
//  Desenvolvimento local:
//    MQTT_HOST = "192.168.0.X"  (PC com Mosquitto)
//    MQTT_PORT = 1883
//
//  Produção na nuvem:
//    MQTT_HOST = "broker.suaempresa.com"
//    MQTT_PORT = 8883  (TLS)
//
//  Teste gratuito (HiveMQ):
//    MQTT_HOST = "broker.hivemq.com"
//    MQTT_PORT = 1883
// ============================================================
